@model LipaCityARTA.ViewModels.AnalyticsDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Analytics Reports";
}

<link rel="stylesheet" href="@Url.Content("~/css/admin-analytics.css")" />

<div class="ar-page">

    <div class="ar-header">
        <div class="ar-header-text">
            <p class="ar-eyebrow">Admin Analytics</p>
            <h1>Analytics Reports</h1>
        </div>

        <div class="ar-header-meta">
            <div class="ar-meta-card">
                <span>Selected Range</span>
                <strong>@Model.From.ToString("MMM dd, yyyy") - @Model.To.ToString("MMM dd, yyyy")</strong>
            </div>
        </div>
    </div>

    <div class="ar-filter-card">
        <form method="get" class="ar-filters">
            <div class="ar-field">
                <label>From</label>
                <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
            </div>

            <div class="ar-field">
                <label>To</label>
                <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
            </div>

            <div class="ar-field">
                <label>Office</label>
                <select name="office">
                    <option value="">All Offices</option>
                    @foreach (var officeName in Model.Offices)
                    {
                        <option value="@officeName" selected="@(Model.Office == officeName)">
                            @officeName
                        </option>
                    }
                </select>
            </div>

            <div class="ar-field ar-field-action">
                <button type="submit" class="ar-btn">Apply Filters</button>
            </div>
        </form>
    </div>

    <div class="ar-kpi-grid">
        <div class="ar-kpi-card">
            <div class="ar-k-title">Total Submissions</div>
            <div class="ar-k-value">@(Model.TotalSurveys + Model.TotalComplaints)</div>
        </div>

        <div class="ar-kpi-card">
            <div class="ar-k-title">Total Surveys</div>
            <div class="ar-k-value">@Model.TotalSurveys</div>
        </div>

        <div class="ar-kpi-card">
            <div class="ar-k-title">Total Complaints</div>
            <div class="ar-k-value">@Model.TotalComplaints</div>
        </div>

        <div class="ar-kpi-card">
            <div class="ar-k-title">Avg Satisfaction</div>
            <div class="ar-k-value">@Model.AvgSatisfaction.ToString("0.00")</div>
            <div class="ar-k-sub">Average score from 1 to 5</div>
        </div>
    </div>

    <div class="ar-grid ar-grid-main">
        <div class="ar-card">
            <div class="ar-card-h">
                <div>
                    <h3>Office-to-Office Comparison</h3>
                    <p>Complaint volume versus satisfaction score per office.</p>
                </div>
            </div>
            <div class="ar-card-b">
                <div class="ar-chart-wrap">
                    <canvas id="officeChart"></canvas>
                </div>
                <div class="ar-note">
                    Satisfaction is shown as a line, while complaints are shown as bars.
                </div>
            </div>
        </div>

        <div class="ar-card">
            <div class="ar-card-h">
                <div>
                    <h3>Top / Bottom Performance</h3>
                    <p>Quick office and question-level insights.</p>
                </div>
            </div>
            <div class="ar-card-b">
                <div class="ar-list-block">
                    <div class="ar-list-card">
                        <b>Top Offices (Satisfaction)</b>
                        <ul class="ar-list">
                            @foreach (var x in Model.TopOffices)
                            {
                                <li>@x.Office — @x.Score.ToString("0.00")</li>
                            }
                        </ul>
                    </div>

                    <div class="ar-list-card">
                        <b>Bottom Offices (Satisfaction)</b>
                        <ul class="ar-list">
                            @foreach (var x in Model.BottomOffices)
                            {
                                <li>@x.Office — @x.Score.ToString("0.00")</li>
                            }
                        </ul>
                    </div>

                    <div class="ar-list-card">
                        <b>Lowest Survey Questions</b>
                        <ul class="ar-list">
                            @foreach (var q in Model.LowestQuestions)
                            {
                                <li>@q.Question — @q.Score.ToString("0.00")</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="application/json" id="officesJson">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Offices ?? new List<string>()))
</script>

<script type="application/json" id="officeSatJson">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficeSatisfaction ?? new List<double>()))
</script>

<script type="application/json" id="officeCmpJson">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficeComplaints ?? new List<int>()))
</script>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const readJson = (id) => {
                const el = document.getElementById(id);
                return el ? JSON.parse(el.textContent) : [];
            };

            const offices = readJson("officesJson");
            const satisfaction = readJson("officeSatJson");
            const complaints = readJson("officeCmpJson");

            const officeCanvas = document.getElementById("officeChart");
            if (!officeCanvas) return;

            new Chart(officeCanvas, {
                data: {
                    labels: offices,
                    datasets: [
                        {
                            type: "bar",
                            label: "Complaints",
                            data: complaints,
                            backgroundColor: "rgba(124, 10, 2, 0.78)",
                            borderRadius: 10,
                            yAxisID: "yComplaints"
                        },
                        {
                            type: "line",
                            label: "Satisfaction",
                            data: satisfaction,
                            borderColor: "#f59e0b",
                            backgroundColor: "rgba(245, 158, 11, 0.15)",
                            fill: false,
                            tension: 0.35,
                            pointRadius: 4,
                            pointHoverRadius: 5,
                            yAxisID: "ySatisfaction"
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: "index",
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            position: "top"
                        },
                        tooltip: {
                            enabled: true
                        }
                    },
                    scales: {
                        x: {
                            grid: {
                                display: false
                            }
                        },
                        yComplaints: {
                            type: "linear",
                            position: "left",
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: "Complaints"
                            },
                            ticks: {
                                precision: 0
                            }
                        },
                        ySatisfaction: {
                            type: "linear",
                            position: "right",
                            beginAtZero: true,
                            min: 0,
                            max: 5,
                            grid: {
                                drawOnChartArea: false
                            },
                            title: {
                                display: true,
                                text: "Satisfaction"
                            }
                        }
                    }
                }
            });
        });
    </script>
}