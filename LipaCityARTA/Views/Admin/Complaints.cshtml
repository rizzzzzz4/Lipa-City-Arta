@model LipaCityARTA.ViewModels.ComplaintListViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Complaints";

    var complaints = Model.Complaints ?? new List<LipaCityARTA.Models.Complaint>();

    var pendingComplaints = complaints
        .Where(c => (c.Status ?? "Pending").Trim() == "Pending")
        .ToList();

    var inProgressComplaints = complaints
        .Where(c =>
            (c.Status ?? "").Trim() == "In Progress" ||
            (c.Status ?? "").Trim() == "Overdue" ||
            (c.Status ?? "").Trim() == "Escalated")
        .ToList();

    var resolvedComplaints = complaints
        .Where(c => (c.Status ?? "").Trim() == "Resolved")
        .ToList();
}

<link rel="stylesheet" href="@Url.Content("~/css/admin-complaints.css")" />

<div class="c-page">

    <div class="c-header">
        <div class="c-header-text">
            <p class="c-eyebrow">Admin Operations</p>
            <h1>Complaints Management</h1>
            <p class="c-subtitle">
                Track complaint submissions, monitor workflow status, and manage pending, active, and resolved cases.
            </p>
        </div>

        <div class="c-header-meta">
            <div class="c-meta-card">
                <span>Board Summary</span>
                <strong>@complaints.Count complaint records</strong>
            </div>
        </div>
    </div>

    <div class="c-toolbar-card">
        <div class="c-toolbar">

            <div class="c-search-wrap">
                <label for="complaintSearch">Search</label>
                <input id="complaintSearch" placeholder="Search complaints..." />
            </div>

            <div class="c-filter">
                <label>Office</label>
                <select id="filterOffice">
                    <option value="">All</option>
                    @foreach (var office in complaints
                                        .Where(c => !string.IsNullOrWhiteSpace(c.Office))
                                        .Select(c => c.Office)
                                        .Distinct())
                    {
                        <option value="@office">@office</option>
                    }
                </select>
            </div>

            <div class="c-filter">
                <label>Client Type</label>
                <select id="filterClient">
                    <option value="">All</option>
                    @foreach (var type in complaints
                                        .Where(c => !string.IsNullOrWhiteSpace(c.ClientType))
                                        .Select(c => c.ClientType)
                                        .Distinct())
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>

            <div class="c-filter">
                <label>From Date</label>
                <input type="date" id="filterFromDate" />
            </div>

            <div class="c-filter">
                <label>To Date</label>
                <input type="date" id="filterToDate" />
            </div>

            <button id="generateReportBtn" class="c-export-btn">
                Generate Report
            </button>

        </div>
    </div>

    <div class="c-kpi-grid">
        <div class="c-kpi-card">
            <div class="c-k-title">Open</div>
            <div class="c-k-value c-open">@Model.OpenCount</div>
            <div class="c-k-sub">Complaints awaiting completion</div>
        </div>

        <div class="c-kpi-card">
            <div class="c-k-title">Overdue</div>
            <div class="c-k-value c-overdue">@Model.OverdueCount</div>
            <div class="c-k-sub">Cases needing urgent attention</div>
        </div>

        <div class="c-kpi-card">
            <div class="c-k-title">New Complaints</div>
            <div class="c-k-value">@Model.NewComplaints</div>
            <div class="c-k-sub">Recently submitted complaints</div>
        </div>

        <div class="c-kpi-card">
            <div class="c-k-title">Resolved</div>
            <div class="c-k-value c-resolved">@Model.ResolvedCount</div>
            <div class="c-k-sub">Cases already completed</div>
        </div>

        <div class="c-kpi-card">
            <div class="c-k-title">Backlog Average</div>
            <div class="c-k-value">@Model.BacklogAvg</div>
            <div class="c-k-sub">Average pending complaint load</div>
        </div>
    </div>

    <div class="c-tabs-card">
        <div class="c-tabs-header">
            <button type="button" class="c-tab-btn active" data-tab="pendingTab">
                Pending <span>@pendingComplaints.Count</span>
            </button>
            <button type="button" class="c-tab-btn" data-tab="progressTab">
                In Progress <span>@inProgressComplaints.Count</span>
            </button>
            <button type="button" class="c-tab-btn" data-tab="resolvedTab">
                Resolved <span>@resolvedComplaints.Count</span>
            </button>
        </div>

        <!-- Pending Tab -->
        <div class="c-tab-panel active" id="pendingTab">
            <div class="c-tab-panel-head c-tab-pending">
                <div>
                    <h3>Pending Complaints</h3>
                    <p>Awaiting initial action</p>
                </div>
            </div>

            @if (pendingComplaints.Any())
            {
                <div class="c-table-wrap">
                    <table class="c-main-table">
                        <thead>
                            <tr>
                                <th>Tracking ID</th>
                                <th>Office</th>
                                <th>Client Type</th>
                                <th>Reason</th>
                                <th>Message</th>
                                <th>Email</th>
                                <th>Date Submitted</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in pendingComplaints)
                            {
                                var shortReason = !string.IsNullOrWhiteSpace(item.Reason) && item.Reason.Length > 40
                                ? item.Reason.Substring(0, 40) + "..."
                                : item.Reason;

                                var shortMessage = !string.IsNullOrWhiteSpace(item.Message) && item.Message.Length > 50
                                ? item.Message.Substring(0, 50) + "..."
                                : item.Message;

                                <tr class="c-ticket"
                                    data-tabgroup="pending"
                                    data-trackingid="@item.TrackingId"
                                    data-office="@item.Office"
                                    data-clienttype="@item.ClientType"
                                    data-reason="@item.Reason"
                                    data-message="@item.Message"
                                    data-email="@item.Email"
                                    data-status="Pending"
                                    data-date="@item.DateSubmitted.ToString("yyyy-MM-dd")">

                                    <td><span class="c-track-id">@item.TrackingId</span></td>
                                    <td>@item.Office</td>
                                    <td>@item.ClientType</td>
                                    <td title="@item.Reason">@shortReason</td>
                                    <td title="@item.Message">@shortMessage</td>
                                    <td>@item.Email</td>
                                    <td>@item.DateSubmitted.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="c-table-actions">
                                            <button type="button" class="c-view-btn js-view-complaint">View</button>

                                            <form asp-controller="Admin" asp-action="AdvanceComplaintStatus" method="post" class="c-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button class="c-mini-btn" type="submit">Start</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="c-empty-panel">No pending complaints.</div>
            }
        </div>

        <!-- In Progress Tab -->
        <div class="c-tab-panel" id="progressTab">
            <div class="c-tab-panel-head c-tab-progress">
                <div>
                    <h3>In Progress Complaints</h3>
                    <p>Currently being handled</p>
                </div>
            </div>

            @if (inProgressComplaints.Any())
            {
                <div class="c-table-wrap">
                    <table class="c-main-table">
                        <thead>
                            <tr>
                                <th>Tracking ID</th>
                                <th>Office</th>
                                <th>Client Type</th>
                                <th>Reason</th>
                                <th>Message</th>
                                <th>Status</th>
                                <th>Email</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in inProgressComplaints)
                            {
                                var s = (item.Status ?? "In Progress").Trim();

                                var statusClass =
                                s == "Escalated" ? "c-st-escalated" :
                                s == "Overdue" ? "c-st-overdue" :
                                                        "c-st-inprogress";

                                var shortReason = !string.IsNullOrWhiteSpace(item.Reason) && item.Reason.Length > 40
                                ? item.Reason.Substring(0, 40) + "..."
                                : item.Reason;

                                var shortMessage = !string.IsNullOrWhiteSpace(item.Message) && item.Message.Length > 50
                                ? item.Message.Substring(0, 50) + "..."
                                : item.Message;

                                <tr class="c-ticket"
                                    data-tabgroup="progress"
                                    data-trackingid="@item.TrackingId"
                                    data-office="@item.Office"
                                    data-clienttype="@item.ClientType"
                                    data-reason="@item.Reason"
                                    data-message="@item.Message"
                                    data-email="@item.Email"
                                    data-status="@s"
                                    data-date="@item.DateSubmitted.ToString("yyyy-MM-dd")">

                                    <td><span class="c-track-id">@item.TrackingId</span></td>
                                    <td>@item.Office</td>
                                    <td>@item.ClientType</td>
                                    <td title="@item.Reason">@shortReason</td>
                                    <td title="@item.Message">@shortMessage</td>
                                    <td><span class="c-status @statusClass">@s</span></td>
                                    <td>@item.Email</td>
                                    <td>
                                        <div class="c-table-actions">
                                            <button type="button" class="c-view-btn js-view-complaint">View</button>

                                            <form asp-controller="Admin" asp-action="AdvanceComplaintStatus" method="post" class="c-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button class="c-mini-btn" type="submit">Resolve</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="c-empty-panel">No complaints in progress.</div>
            }
        </div>

        <!-- Resolved Tab -->
        <div class="c-tab-panel" id="resolvedTab">
            <div class="c-tab-panel-head c-tab-resolved">
                <div>
                    <h3>Resolved Complaints</h3>
                    <p>Completed complaint cases</p>
                </div>
            </div>

            @if (resolvedComplaints.Any())
            {
                <div class="c-table-wrap">
                    <table class="c-main-table">
                        <thead>
                            <tr>
                                <th>Tracking ID</th>
                                <th>Office</th>
                                <th>Client Type</th>
                                <th>Reason</th>
                                <th>Message</th>
                                <th>Email</th>
                                <th>Date Submitted</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in resolvedComplaints)
                            {
                                var shortReason = !string.IsNullOrWhiteSpace(item.Reason) && item.Reason.Length > 40
                                ? item.Reason.Substring(0, 40) + "..."
                                : item.Reason;

                                var shortMessage = !string.IsNullOrWhiteSpace(item.Message) && item.Message.Length > 50
                                ? item.Message.Substring(0, 50) + "..."
                                : item.Message;

                                <tr class="c-ticket"
                                    data-tabgroup="resolved"
                                    data-trackingid="@item.TrackingId"
                                    data-office="@item.Office"
                                    data-clienttype="@item.ClientType"
                                    data-reason="@item.Reason"
                                    data-message="@item.Message"
                                    data-email="@item.Email"
                                    data-status="Resolved"
                                    data-date="@item.DateSubmitted.ToString("yyyy-MM-dd")">

                                    <td><span class="c-track-id">@item.TrackingId</span></td>
                                    <td>@item.Office</td>
                                    <td>@item.ClientType</td>
                                    <td title="@item.Reason">@shortReason</td>
                                    <td title="@item.Message">@shortMessage</td>
                                    <td>@item.Email</td>
                                    <td>@item.DateSubmitted.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="c-table-actions">
                                            <button type="button" class="c-view-btn js-view-complaint">View</button>
                                            <span class="c-done">Done</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="c-empty-panel">No resolved complaints.</div>
            }
        </div>
    </div>

    <div id="complaintModal" class="c-modal">
        <div class="c-modal-box">
            <div class="c-modal-head">
                <h3>Complaint Details</h3>
                <button type="button" class="c-modal-close" id="closeComplaintModal">×</button>
            </div>

            <div class="c-modal-body">
                <div class="c-modal-row"><strong>Tracking ID:</strong> <span id="mTrackingId"></span></div>
                <div class="c-modal-row"><strong>Office:</strong> <span id="mOffice"></span></div>
                <div class="c-modal-row"><strong>Client Type:</strong> <span id="mClientType"></span></div>
                <div class="c-modal-row"><strong>Email:</strong> <span id="mEmail"></span></div>
                <div class="c-modal-row"><strong>Status:</strong> <span id="mStatus"></span></div>
                <div class="c-modal-row"><strong>Date:</strong> <span id="mDate"></span></div>
                <div class="c-modal-row"><strong>Reason / Issue:</strong><p id="mReason"></p></div>
                <div class="c-modal-row"><strong>Message:</strong><p id="mMessage"></p></div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const search = document.getElementById("complaintSearch");
            const filterOffice = document.getElementById("filterOffice");
            const filterClient = document.getElementById("filterClient");
            const filterFromDate = document.getElementById("filterFromDate");
            const filterToDate = document.getElementById("filterToDate");
            const generateReportBtn = document.getElementById("generateReportBtn");

            const tabButtons = document.querySelectorAll(".c-tab-btn");
            const tabPanels = document.querySelectorAll(".c-tab-panel");

            const modal = document.getElementById("complaintModal");
            const closeModalBtn = document.getElementById("closeComplaintModal");

            const mTrackingId = document.getElementById("mTrackingId");
            const mOffice = document.getElementById("mOffice");
            const mClientType = document.getElementById("mClientType");
            const mEmail = document.getElementById("mEmail");
            const mStatus = document.getElementById("mStatus");
            const mDate = document.getElementById("mDate");
            const mReason = document.getElementById("mReason");
            const mMessage = document.getElementById("mMessage");

            function openComplaintModal(ticket) {
                mTrackingId.textContent = ticket.dataset.trackingid || "";
                mOffice.textContent = ticket.dataset.office || "";
                mClientType.textContent = ticket.dataset.clienttype || "";
                mEmail.textContent = ticket.dataset.email || "";
                mStatus.textContent = ticket.dataset.status || "";
                mDate.textContent = ticket.dataset.date || "";
                mReason.textContent = ticket.dataset.reason || "";
                mMessage.textContent = ticket.dataset.message || "";
                modal.style.display = "flex";
                document.body.style.overflow = "hidden";
            }

            function closeComplaintModal() {
                modal.style.display = "none";
                document.body.style.overflow = "";
            }

            document.querySelectorAll(".js-view-complaint").forEach(button => {
                button.addEventListener("click", function () {
                    const ticket = this.closest(".c-ticket");
                    if (ticket) openComplaintModal(ticket);
                });
            });

            if (closeModalBtn) {
                closeModalBtn.addEventListener("click", closeComplaintModal);
            }

            window.addEventListener("click", function (e) {
                if (e.target === modal) {
                    closeComplaintModal();
                }
            });

            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape" && modal.style.display === "flex") {
                    closeComplaintModal();
                }
            });

            tabButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    const target = this.dataset.tab;

                    tabButtons.forEach(b => b.classList.remove("active"));
                    tabPanels.forEach(p => p.classList.remove("active"));

                    this.classList.add("active");
                    document.getElementById(target)?.classList.add("active");

                    applyFilters();
                });
            });

            function applyFilters() {
                const q = (search?.value || "").toLowerCase().trim();
                const officeValue = (filterOffice?.value || "").toLowerCase().trim();
                const clientValue = (filterClient?.value || "").toLowerCase().trim();
                const fromDate = filterFromDate?.value || "";
                const toDate = filterToDate?.value || "";

                const tickets = document.querySelectorAll(".c-ticket");
                const panels = document.querySelectorAll(".c-tab-panel");

                tickets.forEach(ticket => {
                    const text = ticket.innerText.toLowerCase();
                    const office = (ticket.dataset.office || "").toLowerCase().trim();
                    const client = (ticket.dataset.clienttype || "").toLowerCase().trim();
                    const ticketDate = ticket.dataset.date || "";

                    let visible = true;

                    if (q && !text.includes(q)) visible = false;
                    if (officeValue && office !== officeValue) visible = false;
                    if (clientValue && client !== clientValue) visible = false;
                    if (fromDate && ticketDate < fromDate) visible = false;
                    if (toDate && ticketDate > toDate) visible = false;

                    ticket.style.display = visible ? "" : "none";
                });

                panels.forEach(panel => {
                    const allTickets = panel.querySelectorAll(".c-ticket");
                    const visibleTickets = Array.from(allTickets).filter(t => t.style.display !== "none");
                    const emptySearch = panel.querySelector(".c-search-empty");

                    if (emptySearch) emptySearch.remove();

                    if (allTickets.length > 0 && visibleTickets.length === 0) {
                        const div = document.createElement("div");
                        div.className = "c-empty-panel c-search-empty";
                        div.textContent = "No matching complaints.";
                        panel.appendChild(div);
                    }
                });
            }

            async function loadImageAsBase64(url) {
                try {
                    const response = await fetch(url);
                    const blob = await response.blob();

                    return await new Promise((resolve, reject) => {
                        const reader = new FileReader();
                        reader.onloadend = () => resolve(reader.result);
                        reader.onerror = reject;
                        reader.readAsDataURL(blob);
                    });
                } catch {
                    return null;
                }
            }

            function formatPrettyDate(dateStr) {
                if (!dateStr) return "Not specified";
                const d = new Date(dateStr + "T00:00:00");
                return d.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric"
                });
            }

            function formatDateRange(from, to) {
                if (from && to) return `${formatPrettyDate(from)} - ${formatPrettyDate(to)}`;
                if (from) return `From ${formatPrettyDate(from)}`;
                if (to) return `Until ${formatPrettyDate(to)}`;
                return "All Dates";
            }

            if (search) search.addEventListener("input", applyFilters);
            if (filterOffice) filterOffice.addEventListener("change", applyFilters);
            if (filterClient) filterClient.addEventListener("change", applyFilters);
            if (filterFromDate) filterFromDate.addEventListener("change", applyFilters);
            if (filterToDate) filterToDate.addEventListener("change", applyFilters);

            if (generateReportBtn) {
                        generateReportBtn.addEventListener("click", async function () {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF("l", "mm", "a4");

            const activePanel = document.querySelector(".c-tab-panel.active");
            if (!activePanel) {
                alert("No active tab selected.");
                return;
            }

            const visibleRows = Array.from(activePanel.querySelectorAll("tbody tr"))
                .filter(row => row.style.display !== "none");

            if (visibleRows.length === 0) {
                alert("No visible complaint records to export.");
                return;
            }

            const officeFilter = filterOffice?.value || "All Offices";
            const from = filterFromDate?.value || "";
            const to = filterToDate?.value || "";

            const activeTabBtn = document.querySelector(".c-tab-btn.active");
            const statusText = activeTabBtn
                ? activeTabBtn.childNodes[0].textContent.trim()
                : "All Statuses";

            function shortenText(text, maxLength) {
                if (!text) return "";
                text = text.trim();
                return text.length > maxLength ? text.substring(0, maxLength) + "..." : text;
            }

            function formatPrettyDate(dateStr) {
                if (!dateStr) return "Not specified";
                const d = new Date(dateStr + "T00:00:00");
                return d.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric"
                });
            }

            function formatDateRange(from, to) {
                if (from && to) return `${formatPrettyDate(from)} - ${formatPrettyDate(to)}`;
                if (from) return `From ${formatPrettyDate(from)}`;
                if (to) return `Until ${formatPrettyDate(to)}`;
                return "All Dates";
            }

            const tableData = visibleRows.map(row => [
                row.dataset.trackingid || "",
                row.dataset.date || "",
                shortenText(row.dataset.office || "", 30),
                shortenText(row.dataset.clienttype || "", 14),
                shortenText(row.dataset.reason || "", 42),
                shortenText(row.dataset.message || "", 40),
                shortenText(row.dataset.email || "", 28)
            ]);

            const logoBase64 = await loadImageAsBase64("/images/logo.png");

            const pageWidth = doc.internal.pageSize.getWidth();
            const pageHeight = doc.internal.pageSize.getHeight();

            // Header accent line
            doc.setDrawColor(157, 11, 15);
            doc.setLineWidth(1.2);
            doc.line(12, 12, pageWidth - 12, 12);

            // Logo
            if (logoBase64) {
                doc.addImage(logoBase64, "PNG", 14, 16, 20, 20);
            }

            // Header text
            doc.setTextColor(20, 20, 20);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(20);
            doc.text("Lipa City", 38, 24);

            doc.setFont("helvetica", "bold");
            doc.setFontSize(11);
            doc.text("Anti-Red Tape Authority", 38, 31);

            // Report title
            doc.setFont("helvetica", "bold");
            doc.setFontSize(15);
            doc.text("COMPLAINT MONITORING REPORT", 14, 46);

            // Subtitle
            doc.setFont("helvetica", "normal");
            doc.setFontSize(10);
            doc.setTextColor(80, 80, 80);
            doc.text("Official summary of complaint records based on selected filters.", 14, 52);

            // Meta box
            doc.setDrawColor(210, 210, 210);
            doc.setFillColor(248, 249, 251);
            doc.roundedRect(14, 58, pageWidth - 28, 22, 2, 2, "FD");

            doc.setTextColor(0, 0, 0);
            doc.setFont("helvetica", "bold");
            doc.setFontSize(10);
            doc.text("Office:", 18, 66);
            doc.text("Date Range:", 18, 73);
            doc.text("Status:", 110, 66);
            doc.text("Total Records:", 110, 73);

            doc.setFont("helvetica", "normal");
            doc.text(officeFilter, 34, 66);
            doc.text(formatDateRange(from, to), 40, 73);
            doc.text(statusText, 126, 66);
            doc.text(String(visibleRows.length), 136, 73);

            // Table
            doc.autoTable({
                startY: 88,
                head: [[
                    "Tracking ID",
                    "Date",
                    "Office",
                    "Client Type",
                    "Reason",
                    "Message",
                    "Email"
                ]],
                body: tableData,
                theme: "grid",
                styles: {
                    font: "helvetica",
                    fontSize: 8,
                    cellPadding: 3,
                    overflow: "linebreak",
                    valign: "top",
                    textColor: [35, 35, 35],
                    lineColor: [180, 180, 180],
                    lineWidth: 0.15
                },
                headStyles: {
                    fillColor: [157, 11, 15],
                    textColor: [255, 255, 255],
                    fontStyle: "bold",
                    halign: "left",
                    valign: "middle",
                    lineColor: [157, 11, 15],
                    lineWidth: 0.2
                },
                alternateRowStyles: {
                    fillColor: [248, 248, 248]
                },
                columnStyles: {
                    0: { cellWidth: 32 },
                    1: { cellWidth: 22 },
                    2: { cellWidth: 38 },
                    3: { cellWidth: 24 },
                    4: { cellWidth: 52 },
                    5: { cellWidth: 42 },
                    6: { cellWidth: 42 }
                },
                margin: {
                    left: 14,
                    right: 14
                },
                didDrawPage: function (data) {
                    // Footer line
                    doc.setDrawColor(200, 200, 200);
                    doc.setLineWidth(0.3);
                    doc.line(14, pageHeight - 12, pageWidth - 14, pageHeight - 12);

                    // Footer text
                    doc.setFontSize(8);
                    doc.setTextColor(90, 90, 90);
                    doc.setFont("helvetica", "normal");
                    doc.text(
                        `Generated on ${new Date().toLocaleString()}`,
                        14,
                        pageHeight - 7
                    );

                    doc.text(
                        "Prepared by ARTA Admin System",
                        pageWidth / 2,
                        pageHeight - 7,
                        { align: "center" }
                    );

                    const pageNumber = doc.getNumberOfPages();
                    doc.text(
                        `Page ${pageNumber}`,
                        pageWidth - 14,
                        pageHeight - 7,
                        { align: "right" }
                    );
                }
            });

            const filenameDate = new Date().toISOString().slice(0, 10);
            const safeStatus = statusText.replace(/\s+/g, "_");
            doc.save(`ARTA_Complaint_Report_${safeStatus}_${filenameDate}.pdf`);
        });
                        }
                    });

    </script>
}