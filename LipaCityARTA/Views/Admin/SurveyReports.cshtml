@model List<LipaCityARTA.Models.SurveyResponse>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Survey Reports";

    var responses = Model ?? new List<LipaCityARTA.Models.SurveyResponse>();
    var total = responses.Count;

    double avgAge = total > 0 ? responses.Average(x => x.Age) : 0;

    double Avg(Func<LipaCityARTA.Models.SurveyResponse, int> selector) =>
        total > 0 ? responses.Average(x => (double)selector(x)) : 0;

    var avgSQD = new double[]
    {
        Avg(x => x.SQD0),
        Avg(x => x.SQD1),
        Avg(x => x.SQD2),
        Avg(x => x.SQD3),
        Avg(x => x.SQD4),
        Avg(x => x.SQD5),
        Avg(x => x.SQD6),
        Avg(x => x.SQD7),
        Avg(x => x.SQD8)
    };

    var overallAvgSQD = total > 0 ? avgSQD.Average() : 0;

    int maleCount = total > 0 ? responses.Count(x => (x.Sex ?? "").Trim().ToLower() == "male") : 0;
    int femaleCount = total > 0 ? responses.Count(x => (x.Sex ?? "").Trim().ToLower() == "female") : 0;
    int otherSexCount = total - maleCount - femaleCount;

    var clientTypeGroups = total > 0
        ? responses.GroupBy(x => (x.ClientType ?? "Unknown").Trim())
              .Select(g => new LipaCityARTA.Models.GroupCount
              {
                  Name = g.Key,
                  Count = g.Count()
              })
              .OrderByDescending(x => x.Count)
              .ToList()
        : new List<LipaCityARTA.Models.GroupCount>();

    var officeGroups = total > 0
        ? responses.GroupBy(x => (x.Office ?? "Unknown").Trim())
              .Select(g => new LipaCityARTA.Models.GroupCount
              {
                  Name = g.Key,
                  Count = g.Count()
              })
              .OrderByDescending(x => x.Count)
              .ToList()
        : new List<LipaCityARTA.Models.GroupCount>();

    var topClientType = clientTypeGroups.Any() ? clientTypeGroups.First().Name : "N/A";
    var topOffice = officeGroups.Any() ? officeGroups.First().Name : "N/A";

    var offices = officeGroups.Select(o => (string)o.Name).ToList();
    var clientTypes = clientTypeGroups.Select(c => (string)c.Name).ToList();
}

<link rel="stylesheet" href="@Url.Content("~/css/admin-survey-reports.css")" />

<div class="sr-page">

    <div class="sr-header">
        <div class="sr-header-text">
            <p class="sr-eyebrow">Admin Analytics</p>
            <h1 class="sr-page-title">Survey Reports</h1>
        </div>

        <div class="sr-header-meta">
            <div class="sr-meta-card">
                <span class="sr-meta-label">Last Updated</span>
                <strong>@DateTime.Now.ToString("MMM dd, yyyy hh:mm tt")</strong>
            </div>
        </div>
    </div>

    <div class="sr-kpi-grid">
        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Total Responses</div>
            <p class="sr-kpi-value" id="kpiTotal">@total</p>
            <div class="sr-kpi-sub">All submitted surveys</div>
        </div>

        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Average Age</div>
            <p class="sr-kpi-value" id="kpiAvgAge">@avgAge.ToString("0.0")</p>
            <div class="sr-kpi-sub">Across all respondents</div>
        </div>

        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Overall SQD Average</div>
            <p class="sr-kpi-value" id="kpiOverallSQD">@overallAvgSQD.ToString("0.00")</p>
            <div class="sr-kpi-sub">Average of SQD0–SQD8</div>
        </div>

        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Top Office</div>
            <p class="sr-kpi-value sr-kpi-value-small" id="kpiTopOffice">@topOffice</p>
            <div class="sr-kpi-sub">Office with most responses</div>
        </div>
    </div>

    <div class="sr-card sr-filters">
        <div class="sr-card-top">
            <div>
                <div class="sr-section-title">Filters</div>
                <p class="sr-section-subtitle">Refine the displayed survey data using the options below.</p>
            </div>

            <div class="sr-filter-actions">
                <button type="button" class="sr-btn sr-btn-primary" id="btnApply">Apply</button>
                <button type="button" class="sr-btn sr-btn-secondary" id="btnReset">Reset</button>
                <button type="button" id="generateSurveyReportBtn" class="c-export-btn">
                    Generate Report
                </button>
            </div>
        </div>

        <div class="sr-divider"></div>

        <div class="sr-filter-grid">
            <div class="sr-field">
                <label>Office</label>
                <select id="fOffice">
                    <option value="">All</option>
                    @foreach (var o in offices)
                    {
                        <option value="@o">@o</option>
                    }
                </select>
            </div>

            <div class="sr-field">
                <label>Sex</label>
                <select id="fSex">
                    <option value="">All</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <option value="other">Other</option>
                </select>
            </div>

            <div class="sr-field">
                <label>Client Type</label>
                <select id="fClientType">
                    <option value="">All</option>
                    @foreach (var ct in clientTypes)
                    {
                        <option value="@ct">@ct</option>
                    }
                </select>
            </div>

            <div class="sr-field">
                <label>Age Min</label>
                <input type="number" id="fAgeMin" min="1" max="120" placeholder="e.g. 18" />
            </div>

            <div class="sr-field">
                <label>Age Max</label>
                <input type="number" id="fAgeMax" min="1" max="120" placeholder="e.g. 60" />
            </div>

            <div class="sr-field">
                <label>From Date</label>
                <input type="date" id="fFrom" />
            </div>

            <div class="sr-field">
                <label>To Date</label>
                <input type="date" id="fTo" />
            </div>

            <div class="sr-count-wrap">
                <span class="sr-badge" id="filteredCount">Showing: @total / @total</span>
            </div>
        </div>
    </div>

    <div class="sr-card sr-chart-card">
        <div class="sr-chart-head">
            <div class="sr-chart-title">Average Ratings (SQD0–SQD8)</div>
            <p class="sr-chart-subtitle">Average score per service quality dimension.</p>
        </div>
        <div class="sr-chart-box sr-chart-box-sm">
            <canvas id="sqdChart"></canvas>
        </div>
    </div>

    <div class="sr-card sr-chart-card">
        <div class="sr-chart-head">
            <div class="sr-chart-title">Sex Distribution</div>
            <p class="sr-chart-subtitle">Breakdown of respondents by sex.</p>
        </div>
        <div class="sr-chart-box sr-chart-box-md">
            <canvas id="sexChart"></canvas>
        </div>
    </div>

    <div class="sr-card sr-chart-card">
        <div class="sr-chart-head">
            <div class="sr-chart-title">Client Type Distribution</div>
            <p class="sr-chart-subtitle">Response volume by client type.</p>
        </div>
        <div class="sr-chart-box sr-chart-box-md">
            <canvas id="clientChart"></canvas>
        </div>
    </div>

    <div class="sr-card sr-card-wide sr-chart-card">
        <div class="sr-chart-head">
            <div class="sr-chart-title">Top Offices</div>
            <p class="sr-chart-subtitle">Offices with the highest number of survey responses.</p>
        </div>
        <div class="sr-chart-box sr-chart-box-lg">
            <canvas id="officeChart"></canvas>
        </div>
    </div>

    <div class="sr-card sr-table-wrap">
        <div class="sr-table-head">
            <div>
                <div class="sr-section-title">Survey Response Records</div>
                <p class="sr-section-subtitle">Detailed table of all submitted survey responses.</p>
            </div>

            <div class="sr-table-summary-grid">
                <div class="sr-table-summary">
                    <span class="sr-muted">Top Client Type</span>
                    <strong id="topClientTypeText">@topClientType</strong>
                </div>

                <div class="sr-table-summary">
                    <span class="sr-muted">Top Office</span>
                    <strong id="topOfficeSummary">@topOffice</strong>
                </div>

                <div class="sr-table-summary">
                    <span class="sr-muted">Visible Records</span>
                    <strong id="tableVisibleCount">@total</strong>
                </div>
            </div>
        </div>

        <div class="sr-table-toolbar">
            <div class="sr-table-search">
                <label for="tableSearch">Quick Search</label>
                <input type="text" id="tableSearch" placeholder="Search office, client type, suggestion, or date..." />
            </div>

            <div class="sr-table-toolbar-note">
                <span id="filteredCount">Showing: @total / @total</span>
            </div>
        </div>

        <div class="sr-table-scroll">
            <table class="sr-table" id="surveyTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Office</th>
                        <th>Age</th>
                        <th>Sex</th>
                        <th>Client Type</th>
                        <th>CC1</th>
                        <th>CC2</th>
                        <th>CC3</th>
                        <th>SQD Summary</th>
                        <th>Suggestions</th>
                        <th>Date Submitted</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in responses)
                    {
                        var sex = (s.Sex ?? "").Trim();
                        var clientType = (s.ClientType ?? "").Trim();
                        var office = (s.Office ?? "").Trim();

                        var sexNorm = sex.ToLower();
                        var clientNorm = clientType.ToLower();
                        var officeNorm = office.ToLower();

                        var dateIso = s.DateSubmitted.ToString("yyyy-MM-dd");

                        var sqdValues = new[] { s.SQD0, s.SQD1, s.SQD2, s.SQD3, s.SQD4, s.SQD5, s.SQD6, s.SQD7, s.SQD8 };
                        var rowAvgSqd = sqdValues.Average();

                        <tr class="data-row"
                            data-office="@officeNorm"
                            data-sex="@sexNorm"
                            data-client="@clientNorm"
                            data-age="@s.Age"
                            data-date="@dateIso">

                            <td>
                                <span class="sr-id-pill">#@s.Id</span>
                            </td>

                            <td>
                                <div class="sr-office-cell">@office</div>
                            </td>

                            <td>@s.Age</td>

                            <td>
                                <span class="sr-chip @(sexNorm == "male" ? "sr-chip-blue" : sexNorm == "female" ? "sr-chip-pink" : "sr-chip-gray")">
                                    @sex
                                </span>
                            </td>

                            <td>
                                <span class="sr-chip sr-chip-neutral">@clientType</span>
                            </td>

                            <td>@s.CC1</td>
                            <td>@s.CC2</td>
                            <td>@s.CC3</td>

                            <td>
                                <div class="sr-sqd-block">
                                    <strong>@rowAvgSqd.ToString("0.00")</strong>
                                    <small>@s.SQD0, @s.SQD1, @s.SQD2, @s.SQD3, @s.SQD4, @s.SQD5, @s.SQD6, @s.SQD7, @s.SQD8</small>
                                </div>
                            </td>

                            <td>
                                <div class="sr-suggestion-cell">
                                    @(string.IsNullOrWhiteSpace(s.Suggestions) ? "—" : s.Suggestions)
                                </div>
                            </td>

                            <td>
                                <div class="sr-date-cell">@s.DateSubmitted.ToString("yy-MM-dd HH:mm")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rows = Array.from(document.querySelectorAll("#surveyTable tbody .data-row"));
            const filteredCountEl = document.getElementById("filteredCount");

            const fOffice = document.getElementById("fOffice");
            const fSex = document.getElementById("fSex");
            const fClientType = document.getElementById("fClientType");
            const fAgeMin = document.getElementById("fAgeMin");
            const fAgeMax = document.getElementById("fAgeMax");
            const fFrom = document.getElementById("fFrom");
            const fTo = document.getElementById("fTo");
            const tableSearch = document.getElementById("tableSearch");

            const btnApply = document.getElementById("btnApply");
            const btnReset = document.getElementById("btnReset");
            const generateSurveyReportBtn = document.getElementById("generateSurveyReportBtn");

            const kpiTotal = document.getElementById("kpiTotal");
            const kpiAvgAge = document.getElementById("kpiAvgAge");
            const kpiOverallSQD = document.getElementById("kpiOverallSQD");
            const kpiTopOffice = document.getElementById("kpiTopOffice");
            const topClientTypeText = document.getElementById("topClientTypeText");
            const tableVisibleCount = document.getElementById("tableVisibleCount");
            const topOfficeSummary = document.getElementById("topOfficeSummary");

            const sqdLabels = ["SQD0", "SQD1", "SQD2", "SQD3", "SQD4", "SQD5", "SQD6", "SQD7", "SQD8"];

            let sqdChart, sexChart, clientChart, officeChart;

            function normalize(v) {
                return (v || "").toString().trim().toLowerCase();
            }

            function parseSQDs(text) {
                if (!text) return [];
                const matches = text.match(/\d+(\.\d+)?/g);
                return matches ? matches.map(x => parseFloat(x) || 0) : [];
            }

            function getVisibleRows() {
                return rows.filter(r => r.style.display !== "none");
            }

            function getDashboardSummary(visibleRows) {
                const total = visibleRows.length;

                let ageTotal = 0;
                let sqdGrandTotal = 0;
                let sqdValueCount = 0;

                const officeMap = {};
                const clientMap = {};

                visibleRows.forEach(r => {
                    const cells = r.querySelectorAll("td");

                    const office = cells[1]?.innerText.trim() || "Unknown";
                    const age = parseInt(cells[2]?.innerText.trim() || "0", 10);
                    const clientType = cells[4]?.innerText.trim() || "Unknown";
                    const sqdText = cells[8]?.innerText || "";
                    const sqds = parseSQDs(sqdText);

                    ageTotal += age;

                    sqds.forEach(v => {
                        sqdGrandTotal += v;
                        sqdValueCount++;
                    });

                    officeMap[office] = (officeMap[office] || 0) + 1;
                    clientMap[clientType] = (clientMap[clientType] || 0) + 1;
                });

                const avgAge = total > 0 ? ageTotal / total : 0;
                const overallSQD = sqdValueCount > 0 ? sqdGrandTotal / sqdValueCount : 0;

                let topOffice = "N/A";
                let topOfficeCount = 0;
                Object.entries(officeMap).forEach(([office, count]) => {
                    if (count > topOfficeCount) {
                        topOfficeCount = count;
                        topOffice = office;
                    }
                });

                let topClientType = "N/A";
                let topClientCount = 0;
                Object.entries(clientMap).forEach(([clientType, count]) => {
                    if (count > topClientCount) {
                        topClientCount = count;
                        topClientType = clientType;
                    }
                });

                return {
                    total,
                    avgAge,
                    overallSQD,
                    topOffice,
                    topClientType
                };
            }

            function updateKPIs(visibleRows) {
                const summary = getDashboardSummary(visibleRows);

                if (kpiTotal) kpiTotal.textContent = summary.total;
                if (kpiAvgAge) kpiAvgAge.textContent = summary.avgAge.toFixed(1);
                if (kpiOverallSQD) kpiOverallSQD.textContent = summary.overallSQD.toFixed(2);
                if (kpiTopOffice) kpiTopOffice.textContent = summary.topOffice;
                if (topClientTypeText) topClientTypeText.textContent = summary.topClientType;
                if (topOfficeSummary) topOfficeSummary.textContent = summary.topOffice;
            }

            function buildCharts(visibleRows) {
                const sqdTotals = Array(9).fill(0);
                let sqdCount = 0;

                let male = 0, female = 0, other = 0;
                const clientMap = {};
                const officeMap = {};

                visibleRows.forEach(r => {
                    const cells = r.querySelectorAll("td");

                    const office = cells[1]?.innerText.trim() || "Unknown";
                    const sex = normalize(cells[3]?.innerText);
                    const clientType = cells[4]?.innerText.trim() || "Unknown";
                    const sqdText = cells[8]?.innerText || "";

                    const sqds = parseSQDs(sqdText);
                    if (sqds.length >= 9) {
                        for (let i = 0; i < 9; i++) {
                            sqdTotals[i] += sqds[i];
                        }
                        sqdCount++;
                    }

                    if (sex === "male") male++;
                    else if (sex === "female") female++;
                    else other++;

                    clientMap[clientType] = (clientMap[clientType] || 0) + 1;
                    officeMap[office] = (officeMap[office] || 0) + 1;
                });

                const sqdAvg = sqdTotals.map(x => sqdCount > 0 ? x / sqdCount : 0);

                const clientLabels = Object.keys(clientMap);
                const clientCounts = Object.values(clientMap);

                const sortedOffices = Object.entries(officeMap)
                    .sort((a, b) => b[1] - a[1])
                    .slice(0, 10);

                const officeLabels = sortedOffices.map(x => x[0]);
                const officeCounts = sortedOffices.map(x => x[1]);

                if (sqdChart) sqdChart.destroy();
                if (sexChart) sexChart.destroy();
                if (clientChart) clientChart.destroy();
                if (officeChart) officeChart.destroy();

                sqdChart = new Chart(document.getElementById("sqdChart"), {
                    type: "bar",
                    data: {
                        labels: sqdLabels,
                        datasets: [{
                            label: "Average Rating",
                            data: sqdAvg,
                            backgroundColor: "rgba(124, 10, 2, 0.78)",
                            borderRadius: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            x: { grid: { display: false } },
                            y: {
                                beginAtZero: true,
                                suggestedMax: 5
                            }
                        }
                    }
                });

                sexChart = new Chart(document.getElementById("sexChart"), {
                    type: "pie",
                    data: {
                        labels: ["Male", "Female", "Other"],
                        datasets: [{
                            data: [male, female, other],
                            backgroundColor: ["#7C0A02", "#DC2626", "#F59E0B"]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false
                    }
                });

                clientChart = new Chart(document.getElementById("clientChart"), {
                    type: "doughnut",
                    data: {
                        labels: clientLabels,
                        datasets: [{
                            data: clientCounts,
                            backgroundColor: [
                                "#7C0A02", "#B91C1C", "#EF4444", "#F97316",
                                "#F59E0B", "#22C55E", "#06B6D4", "#3B82F6",
                                "#6366F1", "#8B5CF6", "#EC4899", "#14B8A6"
                            ]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false
                    }
                });

                officeChart = new Chart(document.getElementById("officeChart"), {
                    type: "bar",
                    data: {
                        labels: officeLabels,
                        datasets: [{
                            label: "Responses",
                            data: officeCounts,
                            backgroundColor: "rgba(124, 10, 2, 0.78)",
                            borderRadius: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            x: { grid: { display: false } },
                            y: { beginAtZero: true }
                        }
                    }
                });
            }

            function refreshDashboard() {
                const visibleRows = getVisibleRows();

                if (filteredCountEl) {
                    filteredCountEl.textContent = `Showing: ${visibleRows.length} / ${rows.length}`;
                }

                if (tableVisibleCount) {
                    tableVisibleCount.textContent = visibleRows.length;
                }

                updateKPIs(visibleRows);
                buildCharts(visibleRows);
            }

            function applyFilters() {
                const officeVal = normalize(fOffice?.value);
                const sexVal = normalize(fSex?.value);
                const clientVal = normalize(fClientType?.value);
                const searchVal = normalize(tableSearch?.value);

                const ageMin = fAgeMin?.value ? parseInt(fAgeMin.value, 10) : null;
                const ageMax = fAgeMax?.value ? parseInt(fAgeMax.value, 10) : null;

                const fromDate = fFrom?.value ? new Date(fFrom.value + "T00:00:00") : null;
                const toDate = fTo?.value ? new Date(fTo.value + "T23:59:59") : null;

                rows.forEach(r => {
                    const rOffice = normalize(r.dataset.office);
                    const rSex = normalize(r.dataset.sex);
                    const rClient = normalize(r.dataset.client);
                    const rAge = parseInt(r.dataset.age || "0", 10);

                    const rDateStr = r.dataset.date || "";
                    const rDate = rDateStr ? new Date(rDateStr + "T12:00:00") : null;
                    const rowText = normalize(r.innerText);

                    let ok = true;

                    if (officeVal && rOffice !== officeVal) ok = false;

                    if (sexVal) {
                        if (sexVal === "other") {
                            if (rSex === "male" || rSex === "female") ok = false;
                        } else if (rSex !== sexVal) {
                            ok = false;
                        }
                    }

                    if (clientVal && rClient !== clientVal) ok = false;
                    if (ageMin !== null && rAge < ageMin) ok = false;
                    if (ageMax !== null && rAge > ageMax) ok = false;
                    if (fromDate && rDate && rDate < fromDate) ok = false;
                    if (toDate && rDate && rDate > toDate) ok = false;
                    if (searchVal && !rowText.includes(searchVal)) ok = false;

                    r.style.display = ok ? "" : "none";
                });

                refreshDashboard();
            }

            function resetFilters() {
                if (fOffice) fOffice.value = "";
                if (fSex) fSex.value = "";
                if (fClientType) fClientType.value = "";
                if (fAgeMin) fAgeMin.value = "";
                if (fAgeMax) fAgeMax.value = "";
                if (fFrom) fFrom.value = "";
                if (fTo) fTo.value = "";
                if (tableSearch) tableSearch.value = "";

                rows.forEach(r => r.style.display = "");
                refreshDashboard();
            }

            async function loadImageAsBase64(url) {
                try {
                    const response = await fetch(url);
                    const blob = await response.blob();

                    return await new Promise((resolve, reject) => {
                        const reader = new FileReader();
                        reader.onloadend = () => resolve(reader.result);
                        reader.onerror = reject;
                        reader.readAsDataURL(blob);
                    });
                } catch {
                    return null;
                }
            }

            function formatPrettyDate(dateStr) {
                if (!dateStr) return "";
                const d = new Date(dateStr + "T00:00:00");
                return d.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric"
                });
            }

            function formatDateRange(from, to) {
                if (from && to) return `${formatPrettyDate(from)} - ${formatPrettyDate(to)}`;
                if (from) return `From ${formatPrettyDate(from)}`;
                if (to) return `Until ${formatPrettyDate(to)}`;
                return "All Dates";
            }

            function drawJustifiedText(doc, text, x, y, maxWidth, lineHeight) {
                const words = text.split(/\s+/);
                const lines = [];
                let currentLine = "";

                words.forEach(word => {
                    const testLine = currentLine ? currentLine + " " + word : word;
                    const testWidth = doc.getTextWidth(testLine);

                    if (testWidth > maxWidth && currentLine) {
                        lines.push(currentLine);
                        currentLine = word;
                    } else {
                        currentLine = testLine;
                    }
                });

                if (currentLine) {
                    lines.push(currentLine);
                }

                lines.forEach((line, index) => {
                    const isLastLine = index === lines.length - 1;

                    if (isLastLine) {
                        doc.text(line, x, y);
                    } else {
                        const lineWords = line.split(" ");

                        if (lineWords.length === 1) {
                            doc.text(line, x, y);
                        } else {
                            const lineWithoutSpaces = lineWords.join("");
                            const wordsWidth = doc.getTextWidth(lineWithoutSpaces);
                            const totalSpace = maxWidth - wordsWidth;
                            const spaceCount = lineWords.length - 1;
                            const spaceWidth = totalSpace / spaceCount;

                            let cursorX = x;
                            lineWords.forEach((word, i) => {
                                doc.text(word, cursorX, y);
                                if (i < spaceCount) {
                                    cursorX += doc.getTextWidth(word) + spaceWidth;
                                }
                            });
                        }
                    }

                    y += lineHeight;
                });

                return y;
            }

        async function generateSurveyPdf() {
            const visibleRows = getVisibleRows();

            if (visibleRows.length === 0) {
                alert("No visible survey records to export.");
                return;
            }

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF("p", "mm", "a4");

            const logoBase64 = await loadImageAsBase64("/images/logo.png");
            const summary = getDashboardSummary(visibleRows);

            const officeValue = fOffice?.value || "All Offices";
            const sexValue = fSex?.value || "All";
            const clientTypeValue = fClientType?.value || "All";
            const dateRangeText = formatDateRange(fFrom?.value || "", fTo?.value || "");

            const pageWidth = doc.internal.pageSize.getWidth();
            const pageHeight = doc.internal.pageSize.getHeight();

            function addHeader(title, subtitle = "") {
                doc.setFillColor(124, 10, 2);
                doc.rect(0, 0, pageWidth, 22, "F");

                if (logoBase64) {
                    doc.addImage(logoBase64, "PNG", 12, 4, 13, 13);
                }

                doc.setTextColor(255, 255, 255);
                doc.setFont("helvetica", "bold");
                doc.setFontSize(15);
                doc.text(title, 30, 11);

                if (subtitle) {
                    doc.setFont("helvetica", "normal");
                    doc.setFontSize(8.5);
                    doc.text(subtitle, 30, 16);
                }

                doc.setTextColor(0, 0, 0);
            }

            function addFooter(pageNo) {
                doc.setDrawColor(210, 210, 210);
                doc.setLineWidth(0.2);
                doc.line(14, pageHeight - 12, pageWidth - 14, pageHeight - 12);

                doc.setFont("helvetica", "normal");
                doc.setFontSize(8);
                doc.setTextColor(90, 90, 90);
                doc.text(`Generated on ${new Date().toLocaleString()}`, 14, pageHeight - 7);
                doc.text(`Page ${pageNo}`, pageWidth - 14, pageHeight - 7, { align: "right" });

                doc.setTextColor(0, 0, 0);
            }

            function addSectionTitle(text, y) {
                doc.setFont("helvetica", "bold");
                doc.setFontSize(12.5);
                doc.setTextColor(124, 10, 2);
                doc.text(text, 14, y);

                doc.setDrawColor(124, 10, 2);
                doc.setLineWidth(0.35);
                doc.line(14, y + 2, 72, y + 2);

                doc.setTextColor(0, 0, 0);
                return y + 8;
            }

            function addParagraph(text, y, maxWidth = 182) {
                doc.setFont("helvetica", "normal");
                doc.setFontSize(10);
                const lines = doc.splitTextToSize(text, maxWidth);
                doc.text(lines, 14, y);
                return y + lines.length * 5;
            }

            function drawInfoRow(label, value, x, y, labelWidth = 42) {
                doc.setFont("helvetica", "bold");
                doc.setFontSize(9.5);
                doc.text(label, x, y);

                doc.setFont("helvetica", "normal");
                doc.text(String(value), x + labelWidth, y);
            }

            function getSexBreakdown(rows) {
                let male = 0, female = 0, other = 0;

                rows.forEach(r => {
                    const sex = normalize(r.dataset.sex);
                    if (sex === "male") male++;
                    else if (sex === "female") female++;
                    else other++;
                });

                const total = rows.length || 1;

                return {
                    male,
                    female,
                    other,
                    malePct: ((male / total) * 100).toFixed(1),
                    femalePct: ((female / total) * 100).toFixed(1),
                    otherPct: ((other / total) * 100).toFixed(1)
                };
            }

            function getSQDAverages(rows) {
                const totals = Array(9).fill(0);
                let count = 0;

                rows.forEach(r => {
                    const sqdText = r.querySelectorAll("td")[8]?.innerText || "";
                    const sqds = parseSQDs(sqdText);

                    if (sqds.length >= 9) {
                        for (let i = 0; i < 9; i++) {
                            totals[i] += sqds[i];
                        }
                        count++;
                    }
                });

                return totals.map(v => count > 0 ? v / count : 0);
            }

            function getTopItems(rows, cellIndex) {
                const map = {};

                rows.forEach(r => {
                    const value = r.querySelectorAll("td")[cellIndex]?.innerText.trim() || "Unknown";
                    map[value] = (map[value] || 0) + 1;
                });

                return Object.entries(map).sort((a, b) => b[1] - a[1]);
            }

            function getTopSuggestions(rows, limit = 3) {
                return rows
                    .map(r => r.querySelectorAll("td")[9]?.innerText.trim() || "")
                    .filter(x => x && x !== "—")
                    .slice(0, limit);
            }

            function addKpiCard(x, y, w, h, label, value, sub = "") {
                doc.setFillColor(248, 248, 248);
                doc.setDrawColor(225, 225, 225);
                doc.roundedRect(x, y, w, h, 3, 3, "FD");

                doc.setFont("helvetica", "normal");
                doc.setFontSize(8.5);
                doc.setTextColor(90, 90, 90);
                doc.text(label, x + 4, y + 7);

                doc.setFont("helvetica", "bold");
                doc.setFontSize(15);
                doc.setTextColor(124, 10, 2);
                doc.text(String(value), x + 4, y + 16);

                if (sub) {
                    doc.setFont("helvetica", "normal");
                    doc.setFontSize(7.5);
                    doc.setTextColor(100, 100, 100);
                    const lines = doc.splitTextToSize(sub, w - 8);
                    doc.text(lines, x + 4, y + 23);
                }

                doc.setTextColor(0, 0, 0);
            }

            const sexStats = getSexBreakdown(visibleRows);
            const sqdAvg = getSQDAverages(visibleRows);
            const topOffices = getTopItems(visibleRows, 1);
            const topClientTypes = getTopItems(visibleRows, 4);
            const topSuggestions = getTopSuggestions(visibleRows, 3);

            const highestSQD = sqdAvg
                .map((v, i) => ({ label: `SQD${i}`, value: v }))
                .sort((a, b) => b.value - a.value)[0];

            const lowestSQD = sqdAvg
                .map((v, i) => ({ label: `SQD${i}`, value: v }))
                .sort((a, b) => a.value - b.value)[0];

            // PAGE 1
            addHeader("Survey Results Report", "Lipa City Anti-Red Tape Authority");

            let y = 32;

            y = addSectionTitle("Report Overview", y);

            const overviewText =
                `This report presents a summary of survey responses collected through the system based on the selected filters. ` +
                `It highlights respondent volume, service quality performance, and key response patterns to support administrative review and service improvement.`;

            y = addParagraph(overviewText, y);
            y += 4;

            drawInfoRow("Office Scope:", officeValue, 14, y); y += 6;
            drawInfoRow("Sex Filter:", sexValue, 14, y); y += 6;
            drawInfoRow("Client Type:", clientTypeValue, 14, y); y += 6;
            drawInfoRow("Date Coverage:", dateRangeText, 14, y); y += 10;

            y = addSectionTitle("Key Metrics", y);

            addKpiCard(14, y, 42, 28, "Total Responses", summary.total, "Visible records included");
            addKpiCard(59, y, 42, 28, "Average Age", summary.avgAge.toFixed(1), "Across respondents");
            addKpiCard(104, y, 42, 28, "Overall SQD", summary.overallSQD.toFixed(2), "Average of SQD0–SQD8");
            addKpiCard(149, y, 47, 28, "Top Office", topOffices[0]?.[0] || "N/A", "Most responses");

            y += 38;

            y = addSectionTitle("Key Findings", y);

            const findingsText1 =
                `A total of ${summary.total} responses were included in this report. The average age of respondents was ${summary.avgAge.toFixed(1)} years. ` +
                `${sexStats.male} (${sexStats.malePct}%) were male, ${sexStats.female} (${sexStats.femalePct}%) were female, and ${sexStats.other} (${sexStats.otherPct}%) were classified as other or unspecified.`;

            y = addParagraph(findingsText1, y);
            y += 3;

            const findingsText2 =
                `The overall service quality dimension average was ${summary.overallSQD.toFixed(2)}. ` +
                `The highest-rated dimension was ${highestSQD.label} with an average of ${highestSQD.value.toFixed(2)}, while the lowest-rated dimension was ${lowestSQD.label} with an average of ${lowestSQD.value.toFixed(2)}.`;

            y = addParagraph(findingsText2, y);
            y += 3;

            const findingsText3 =
                `The office with the highest response count was ${topOffices[0]?.[0] || "N/A"}, while the most common client type was ${topClientTypes[0]?.[0] || "N/A"}. ` +
                `These patterns may help identify where services are most frequently used and where client feedback is most concentrated.`;

            y = addParagraph(findingsText3, y);

            addFooter(1);

            // PAGE 2
            doc.addPage();
            addHeader("Survey Results Report", "Interpretation and Recommendations");

            y = 32;

            y = addSectionTitle("Interpretation", y);

            const interpretationText =
                "The survey results indicate the current performance of services based on recorded client feedback. " +
                "Higher-scoring SQD dimensions may reflect service strengths, while lower-scoring dimensions can be treated as priority areas for operational review. " +
                "The results should be interpreted as a practical summary of available responses rather than as a full statistical study.";

            y = addParagraph(interpretationText, y);
            y += 6;

            if (topSuggestions.length > 0) {
                y = addSectionTitle("Selected Client Suggestions", y);

                doc.setFont("helvetica", "normal");
                doc.setFontSize(10);

                topSuggestions.forEach((item) => {
                    const lines = doc.splitTextToSize(`• ${item}`, 178);
                    doc.text(lines, 18, y);
                    y += lines.length * 5 + 2;
                });

                y += 3;
            }

            y = addSectionTitle("Recommendations", y);

            const recommendations = [
                "Review the lowest-rated SQD area and identify the service step or process causing lower satisfaction.",
                "Use repeated reports over time to monitor whether service quality scores are improving.",
                "Prioritize offices with high response counts, since they provide stronger feedback volume for decision-making.",
                "Examine written suggestions regularly and group them into common improvement themes.",
                "Maintain a consistent report format to support easier comparison across reporting periods."
            ];

            doc.setFont("helvetica", "normal");
            doc.setFontSize(10);

            recommendations.forEach((rec) => {
                const lines = doc.splitTextToSize(`• ${rec}`, 178);
                doc.text(lines, 18, y);
                y += lines.length * 5 + 2;
            });

            y += 4;
            y = addSectionTitle("Summary", y);

            const summaryText =
                "Overall, this report provides a concise and structured overview of survey performance, respondent characteristics, and service quality patterns. " +
                "It may be used as a reference for management review, process improvement, and regular administrative reporting.";

            y = addParagraph(summaryText, y);

            addFooter(2);

            // PAGE 3 APPENDIX TABLE (TOP 10 ONLY)
            doc.addPage();
            addHeader("Survey Results Report", "Appendix: Top 10 Response Records");

            const limitedRows = visibleRows.slice(0, 10);

            const tableData = limitedRows.map(r => {
                const cells = r.querySelectorAll("td");

                return [
                    cells[0]?.innerText.trim() || "",
                    cells[1]?.innerText.trim() || "",
                    cells[2]?.innerText.trim() || "",
                    cells[3]?.innerText.trim() || "",
                    cells[4]?.innerText.trim() || "",
                    cells[8]?.innerText.trim() || ""
                ];
            });

            doc.setFont("helvetica", "bold");
            doc.setFontSize(12);
            doc.setTextColor(124, 10, 2);
            doc.text("Appendix A. Top 10 Survey Response Details", 14, 30);
            doc.setTextColor(0, 0, 0);

            doc.setFont("helvetica", "normal");
            doc.setFontSize(9);
            doc.text(
                `Showing ${limitedRows.length} of ${visibleRows.length} filtered survey responses.`,
                14,
                36
            );

            doc.autoTable({
                startY: 42,
                head: [[
                    "ID",
                    "Office",
                    "Age",
                    "Sex",
                    "Client Type",
                    "SQD Summary"
                ]],
                body: tableData,
                theme: "grid",
                styles: {
                    font: "helvetica",
                    fontSize: 8,
                    cellPadding: 2.5,
                    overflow: "linebreak",
                    valign: "top",
                    textColor: [35, 35, 35],
                    lineColor: [205, 205, 205],
                    lineWidth: 0.15
                },
                headStyles: {
                    fillColor: [124, 10, 2],
                    textColor: [255, 255, 255],
                    fontStyle: "bold"
                },
                alternateRowStyles: {
                    fillColor: [248, 248, 248]
                },
                columnStyles: {
                    0: { cellWidth: 16 },
                    1: { cellWidth: 42 },
                    2: { cellWidth: 12 },
                    3: { cellWidth: 18 },
                    4: { cellWidth: 34 },
                    5: { cellWidth: 62 }
                },
                margin: { left: 14, right: 14 },
                didDrawPage: function () {
                    const currentPage = doc.internal.getCurrentPageInfo().pageNumber;
                    addHeader("Survey Results Report", "Appendix: Top 10 Response Records");
                    addFooter(currentPage);
                }
            });

            const fileDate = new Date().toISOString().slice(0, 10);
            doc.save(`ARTA_Short_Survey_Report_${fileDate}.pdf`);
        }

            if (btnApply) btnApply.addEventListener("click", applyFilters);
            if (btnReset) btnReset.addEventListener("click", resetFilters);
            if (tableSearch) tableSearch.addEventListener("input", applyFilters);
            if (generateSurveyReportBtn) generateSurveyReportBtn.addEventListener("click", generateSurveyPdf);

            refreshDashboard();
        });
    </script>
}