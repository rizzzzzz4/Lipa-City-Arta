@model List<LipaCityARTA.Models.SurveyResponse>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Survey Reports";

    var responses = Model ?? new List<LipaCityARTA.Models.SurveyResponse>();
    var total = responses.Count;

    double avgAge = total > 0 ? responses.Average(x => x.Age) : 0;

    double Avg(Func<LipaCityARTA.Models.SurveyResponse, int> selector) =>
        total > 0 ? responses.Average(x => (double)selector(x)) : 0;

    var avgSQD = new double[]
    {
        Avg(x => x.SQD0),
        Avg(x => x.SQD1),
        Avg(x => x.SQD2),
        Avg(x => x.SQD3),
        Avg(x => x.SQD4),
        Avg(x => x.SQD5),
        Avg(x => x.SQD6),
        Avg(x => x.SQD7),
        Avg(x => x.SQD8)
    };

    var overallAvgSQD = total > 0 ? avgSQD.Average() : 0;

    int maleCount = total > 0 ? responses.Count(x => (x.Sex ?? "").Trim().ToLower() == "male") : 0;
    int femaleCount = total > 0 ? responses.Count(x => (x.Sex ?? "").Trim().ToLower() == "female") : 0;
    int otherSexCount = total - maleCount - femaleCount;

    var clientTypeGroups = total > 0
        ? responses.GroupBy(x => (x.ClientType ?? "Unknown").Trim())
              .Select(g => new LipaCityARTA.Models.GroupCount
              {
                  Name = g.Key,
                  Count = g.Count()
              })
              .OrderByDescending(x => x.Count)
              .ToList()
        : new List<LipaCityARTA.Models.GroupCount>();

    var officeGroups = total > 0
        ? responses.GroupBy(x => (x.Office ?? "Unknown").Trim())
              .Select(g => new LipaCityARTA.Models.GroupCount
              {
                  Name = g.Key,
                  Count = g.Count()
              })
              .OrderByDescending(x => x.Count)
              .ToList()
        : new List<LipaCityARTA.Models.GroupCount>();

    var topClientType = clientTypeGroups.Any() ? clientTypeGroups.First().Name : "N/A";
    var topOffice = officeGroups.Any() ? officeGroups.First().Name : "N/A";

    var offices = officeGroups.Select(o => (string)o.Name).ToList();
    var clientTypes = clientTypeGroups.Select(c => (string)c.Name).ToList();
}

<link rel="stylesheet" href="@Url.Content("~/css/admin-survey-reports.css")" />

<div class="sr-page">

    <h2 class="sr-page-title">Survey Reports</h2>

    <div class="sr-kpi-grid">
        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Total Responses</div>
            <p class="sr-kpi-value" id="kpiTotal">@total</p>
            <div class="sr-kpi-sub">All submitted surveys</div>
        </div>

        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Average Age</div>
            <p class="sr-kpi-value" id="kpiAvgAge">@avgAge.ToString("0.0")</p>
            <div class="sr-kpi-sub">Across all respondents</div>
        </div>

        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Overall SQD Average</div>
            <p class="sr-kpi-value" id="kpiOverallSQD">@overallAvgSQD.ToString("0.00")</p>
            <div class="sr-kpi-sub">Avg of SQD0–SQD8</div>
        </div>

        <div class="sr-kpi-card">
            <div class="sr-kpi-label">Top Office</div>
            <p class="sr-kpi-value sr-kpi-value-small" id="kpiTopOffice">@topOffice</p>
            <div class="sr-kpi-sub">Most responses</div>
        </div>
    </div>

    <div class="sr-card sr-filters">
        <div class="sr-card-top">
            <div class="sr-section-title">Filters</div>

            <div class="sr-filter-actions">
                <button type="button" class="sr-btn sr-btn-primary" id="btnApply">Apply</button>
                <button type="button" class="sr-btn sr-btn-secondary" id="btnReset">Reset</button>
            </div>
        </div>

        <div class="sr-divider"></div>

        <div class="sr-filter-grid">
            <div class="sr-field">
                <label>Office</label>
                <select id="fOffice">
                    <option value="">All</option>
                    @foreach (var o in offices)
                    {
                        <option value="@o">@o</option>
                    }
                </select>
            </div>

            <div class="sr-field">
                <label>Sex</label>
                <select id="fSex">
                    <option value="">All</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <option value="other">Other</option>
                </select>
            </div>

            <div class="sr-field">
                <label>Client Type</label>
                <select id="fClientType">
                    <option value="">All</option>
                    @foreach (var ct in clientTypes)
                    {
                        <option value="@ct">@ct</option>
                    }
                </select>
            </div>

            <div class="sr-field">
                <label>Age Min</label>
                <input type="number" id="fAgeMin" min="1" max="120" placeholder="e.g. 18" />
            </div>

            <div class="sr-field">
                <label>Age Max</label>
                <input type="number" id="fAgeMax" min="1" max="120" placeholder="e.g. 60" />
            </div>

            <div class="sr-field">
                <label>From Date</label>
                <input type="date" id="fFrom" />
            </div>

            <div class="sr-field">
                <label>To Date</label>
                <input type="date" id="fTo" />
            </div>

            <div class="sr-count-wrap">
                <span class="sr-badge" id="filteredCount">Showing: @total / @total</span>
            </div>
        </div>
    </div>

    <div class="sr-chart-grid">
        <div class="sr-card">
            <div class="sr-chart-title">Average Ratings (SQD0–SQD8)</div>
            <canvas id="sqdChart" height="140"></canvas>
        </div>

        <div class="sr-card">
            <div class="sr-chart-title">Sex Distribution</div>
            <canvas id="sexChart" height="180"></canvas>
        </div>

        <div class="sr-card">
            <div class="sr-chart-title">Client Type Distribution</div>
            <canvas id="clientChart" height="180"></canvas>
        </div>

        <div class="sr-card sr-card-wide">
            <div class="sr-chart-title">Top Offices (by number of responses)</div>
            <canvas id="officeChart" height="110"></canvas>
        </div>
    </div>

    <div class="sr-card sr-table-wrap">
        <div class="sr-table-head">
            <div class="sr-muted">
                Top Client Type: <strong id="topClientTypeText">@topClientType</strong>
            </div>
        </div>

        <div class="sr-table-scroll">
            <table class="sr-table" id="surveyTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Office</th>
                        <th>Age</th>
                        <th>Sex</th>
                        <th>Client Type</th>
                        <th>CC1</th>
                        <th>CC2</th>
                        <th>CC3</th>
                        <th>SQD0-SQD8</th>
                        <th>Suggestions</th>
                        <th>Date Submitted</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in responses)
                    {
                        var sex = (s.Sex ?? "").Trim();
                        var clientType = (s.ClientType ?? "").Trim();
                        var office = (s.Office ?? "").Trim();

                        var sexNorm = sex.ToLower();
                        var clientNorm = clientType.ToLower();
                        var officeNorm = office.ToLower();

                        var dateIso = s.DateSubmitted.ToString("yyyy-MM-dd");

                        <tr class="data-row"
                            data-office="@officeNorm"
                            data-sex="@sexNorm"
                            data-client="@clientNorm"
                            data-age="@s.Age"
                            data-date="@dateIso">

                            <td>@s.Id</td>
                            <td>@office</td>
                            <td>@s.Age</td>
                            <td>@sex</td>
                            <td>@clientType</td>
                            <td>@s.CC1</td>
                            <td>@s.CC2</td>
                            <td>@s.CC3</td>
                            <td>
                                @s.SQD0, @s.SQD1, @s.SQD2, @s.SQD3, @s.SQD4, @s.SQD5, @s.SQD6, @s.SQD7, @s.SQD8
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(s.Suggestions) ? "-" : s.Suggestions)</td>
                            <td>@s.DateSubmitted.ToString("yy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rows = Array.from(document.querySelectorAll("#surveyTable tbody .data-row"));
            const filteredCountEl = document.getElementById("filteredCount");

            const fOffice = document.getElementById("fOffice");
            const fSex = document.getElementById("fSex");
            const fClientType = document.getElementById("fClientType");
            const fAgeMin = document.getElementById("fAgeMin");
            const fAgeMax = document.getElementById("fAgeMax");
            const fFrom = document.getElementById("fFrom");
            const fTo = document.getElementById("fTo");

            const btnApply = document.getElementById("btnApply");
            const btnReset = document.getElementById("btnReset");

            const kpiTotal = document.getElementById("kpiTotal");
            const kpiAvgAge = document.getElementById("kpiAvgAge");
            const kpiOverallSQD = document.getElementById("kpiOverallSQD");
            const kpiTopOffice = document.getElementById("kpiTopOffice");
            const topClientTypeText = document.getElementById("topClientTypeText");

            const sqdLabels = ["SQD0", "SQD1", "SQD2", "SQD3", "SQD4", "SQD5", "SQD6", "SQD7", "SQD8"];

            let sqdChart, sexChart, clientChart, officeChart;

            function normalize(v) {
                return (v || "").toString().trim().toLowerCase();
            }

            function parseSQDs(text) {
                return text.split(",").map(x => parseFloat(x.trim()) || 0);
            }

            function getVisibleRows() {
                return rows.filter(r => r.style.display !== "none");
            }

            function updateKPIs(visibleRows) {
                const total = visibleRows.length;

                let ageTotal = 0;
                let sqdGrandTotal = 0;
                let sqdValueCount = 0;
                const officeMap = {};
                const clientMap = {};

                visibleRows.forEach(r => {
                    const cells = r.querySelectorAll("td");

                    const office = cells[1]?.innerText.trim() || "Unknown";
                    const age = parseInt(cells[2]?.innerText.trim() || "0", 10);
                    const clientType = cells[4]?.innerText.trim() || "Unknown";
                    const sqdText = cells[8]?.innerText || "";
                    const sqds = parseSQDs(sqdText);

                    ageTotal += age;

                    sqds.forEach(v => {
                        sqdGrandTotal += v;
                        sqdValueCount++;
                    });

                    officeMap[office] = (officeMap[office] || 0) + 1;
                    clientMap[clientType] = (clientMap[clientType] || 0) + 1;
                });

                const avgAge = total > 0 ? (ageTotal / total) : 0;
                const overallSQD = sqdValueCount > 0 ? (sqdGrandTotal / sqdValueCount) : 0;

                let topOffice = "N/A";
                let topOfficeCount = 0;
                Object.entries(officeMap).forEach(([office, count]) => {
                    if (count > topOfficeCount) {
                        topOfficeCount = count;
                        topOffice = office;
                    }
                });

                let topClientType = "N/A";
                let topClientCount = 0;
                Object.entries(clientMap).forEach(([clientType, count]) => {
                    if (count > topClientCount) {
                        topClientCount = count;
                        topClientType = clientType;
                    }
                });

                kpiTotal.textContent = total;
                kpiAvgAge.textContent = avgAge.toFixed(1);
                kpiOverallSQD.textContent = overallSQD.toFixed(2);
                kpiTopOffice.textContent = topOffice;
                topClientTypeText.textContent = topClientType;
            }

            function buildCharts(visibleRows) {
                const sqdTotals = Array(9).fill(0);
                let sqdCount = 0;

                let male = 0, female = 0, other = 0;
                const clientMap = {};
                const officeMap = {};

                visibleRows.forEach(r => {
                    const cells = r.querySelectorAll("td");

                    const office = cells[1]?.innerText.trim() || "Unknown";
                    const sex = normalize(cells[3]?.innerText);
                    const clientType = cells[4]?.innerText.trim() || "Unknown";
                    const sqdText = cells[8]?.innerText || "";

                    const sqds = parseSQDs(sqdText);
                    if (sqds.length === 9) {
                        for (let i = 0; i < 9; i++) {
                            sqdTotals[i] += sqds[i];
                        }
                        sqdCount++;
                    }

                    if (sex === "male") male++;
                    else if (sex === "female") female++;
                    else other++;

                    clientMap[clientType] = (clientMap[clientType] || 0) + 1;
                    officeMap[office] = (officeMap[office] || 0) + 1;
                });

                const sqdAvg = sqdTotals.map(x => sqdCount > 0 ? x / sqdCount : 0);

                const clientLabels = Object.keys(clientMap);
                const clientCounts = Object.values(clientMap);

                const sortedOffices = Object.entries(officeMap)
                    .sort((a, b) => b[1] - a[1])
                    .slice(0, 10);

                const officeLabels = sortedOffices.map(x => x[0]);
                const officeCounts = sortedOffices.map(x => x[1]);

                if (sqdChart) sqdChart.destroy();
                if (sexChart) sexChart.destroy();
                if (clientChart) clientChart.destroy();
                if (officeChart) officeChart.destroy();

                sqdChart = new Chart(document.getElementById("sqdChart"), {
                    type: "bar",
                    data: {
                        labels: sqdLabels,
                        datasets: [{
                            label: "Average Rating",
                            data: sqdAvg
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true, suggestedMax: 5 }
                        }
                    }
                });

                sexChart = new Chart(document.getElementById("sexChart"), {
                    type: "pie",
                    data: {
                        labels: ["Male", "Female", "Other"],
                        datasets: [{
                            data: [male, female, other]
                        }]
                    },
                    options: { responsive: true }
                });

                clientChart = new Chart(document.getElementById("clientChart"), {
                    type: "doughnut",
                    data: {
                        labels: clientLabels,
                        datasets: [{
                            data: clientCounts
                        }]
                    },
                    options: { responsive: true }
                });

                officeChart = new Chart(document.getElementById("officeChart"), {
                    type: "bar",
                    data: {
                        labels: officeLabels,
                        datasets: [{
                            label: "Responses",
                            data: officeCounts
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });
            }

            function refreshDashboard() {
                const visibleRows = getVisibleRows();
                filteredCountEl.textContent = `Showing: ${visibleRows.length} / ${rows.length}`;
                updateKPIs(visibleRows);
                buildCharts(visibleRows);
            }

            function applyFilters() {
                const officeVal = normalize(fOffice.value);
                const sexVal = normalize(fSex.value);
                const clientVal = normalize(fClientType.value);

                const ageMin = fAgeMin.value ? parseInt(fAgeMin.value, 10) : null;
                const ageMax = fAgeMax.value ? parseInt(fAgeMax.value, 10) : null;

                const fromDate = fFrom.value ? new Date(fFrom.value + "T00:00:00") : null;
                const toDate = fTo.value ? new Date(fTo.value + "T23:59:59") : null;

                rows.forEach(r => {
                    const rOffice = normalize(r.dataset.office);
                    const rSex = normalize(r.dataset.sex);
                    const rClient = normalize(r.dataset.client);
                    const rAge = parseInt(r.dataset.age || "0", 10);

                    const rDateStr = r.dataset.date || "";
                    const rDate = rDateStr ? new Date(rDateStr + "T12:00:00") : null;

                    let ok = true;

                    if (officeVal && rOffice !== officeVal) ok = false;

                    if (sexVal) {
                        if (sexVal === "other") {
                            if (rSex === "male" || rSex === "female") ok = false;
                        } else if (rSex !== sexVal) {
                            ok = false;
                        }
                    }

                    if (clientVal && rClient !== clientVal) ok = false;
                    if (ageMin !== null && rAge < ageMin) ok = false;
                    if (ageMax !== null && rAge > ageMax) ok = false;
                    if (fromDate && rDate && rDate < fromDate) ok = false;
                    if (toDate && rDate && rDate > toDate) ok = false;

                    r.style.display = ok ? "" : "none";
                });

                refreshDashboard();
            }

            function resetFilters() {
                fOffice.value = "";
                fSex.value = "";
                fClientType.value = "";
                fAgeMin.value = "";
                fAgeMax.value = "";
                fFrom.value = "";
                fTo.value = "";

                rows.forEach(r => r.style.display = "");
                refreshDashboard();
            }

            btnApply.addEventListener("click", applyFilters);
            btnReset.addEventListener("click", resetFilters);

            refreshDashboard();
        });
    </script>
}